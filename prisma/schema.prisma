// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  telegramUsername String?      @unique
  image         String?
  password      String?
  goal          String?
  isPrivate     Boolean      @default(false)
  totalDistance Float        @default(0)
  createdAt     DateTime     @default(now())
  
  accounts      Account[]
  sessions      Session[]
  runs          Run[]
  clubMembers   ClubMember[]
  eventsCreated Event[]      @relation("EventCreator")
  eventsAttended Event[]     @relation("EventAttendees")
  eventsCheckedIn Event[]    @relation("EventCheckedIn")
  
  runProposals  RunProposal[] @relation("RunProposalCreator")
  joinRequests  RunJoinRequest[] @relation("JoinRequestUser")
}

model Run {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  distance      Float    @default(0) // in km
  durationSec   Int      @default(0)
  avgPace       Float    @default(0) // min/km (calculated or stored)
  status        String   @default("COMPLETED") // "IN_PROGRESS" | "COMPLETED"
  routeData     String?  // JSON stringified coordinates
  startTime     DateTime @default(now())
  
  eventId       String?
  event         Event?   @relation("EventRuns", fields: [eventId], references: [id], onDelete: SetNull)
  splits        String?  // JSON stringified array
}

model Club {
  id                String       @id @default(cuid())
  name              String
  description       String?
  logoConfig        String?      // JSON stringified
  joinType          String       @default("OPEN") // "OPEN" | "APPLICATION" | "INVITE_ONLY"
  tags              String?      // JSON stringified array
  inviteCode        String?      @unique
  totalClubDistance Float        @default(0)
  createdAt         DateTime     @default(now())
  
  members           ClubMember[]
  events            Event[]
}

model ClubMember {
  id            String   @id @default(cuid())
  userId        String
  clubId        String
  role          String   @default("MEMBER") // "MEMBER" | "PACER" | "OFFICER" | "FOUNDER"
  status        String   @default("ACTIVE") // "PENDING" | "ACTIVE" | "KICKED"
  joinedAt      DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  @@unique([userId, clubId])
}

model Event {
  id            String   @id @default(cuid())
  clubId        String?
  creatorId     String
  title         String
  description   String?
  location      String
  date          DateTime
  distance      Float?
  pace          String?  // e.g. "5:00-5:30" or JSON array
  routeData     String?  // JSON stringified coordinates
  image         String?
  checkInToken  String?  @unique
  createdAt     DateTime @default(now())
  
  club          Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  creator       User     @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  attendees     User[]   @relation("EventAttendees")
  checkedInUsers User[]  @relation("EventCheckedIn")
  runs          Run[]    @relation("EventRuns")
}

model RunProposal {
  id              String   @id @default(cuid())
  creatorId       String
  lat             Float
  lng             Float
  routeData       String?  // JSON stringified coordinates
  pace            String?
  startTime       DateTime
  maxParticipants Int      @default(0) // 0 means no limit
  status          String   @default("ACTIVE") // ACTIVE, CANCELLED, COMPLETED
  createdAt       DateTime @default(now())

  creator         User     @relation("RunProposalCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  requests        RunJoinRequest[] @relation("RunJoinRequests")
}

model RunJoinRequest {
  id              String   @id @default(cuid())
  proposalId      String
  userId          String
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt       DateTime @default(now())

  proposal        RunProposal @relation("RunJoinRequests", fields: [proposalId], references: [id], onDelete: Cascade)
  user            User        @relation("JoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([proposalId, userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
